{
    "env": {
        "node": true,
        "browser": true,
        "es2021": true,
        "jest": true
    },
    "parserOptions": {
        "ecmaVersion": 2021
    },
    "extends": "eslint:recommended",
    "rules": {
        "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
        "no-console": "off",
        "semi": ["error", "always"],
        "quotes": ["warn", "single", { "avoidEscape": true }],
        "indent": ["warn", 4, { "SwitchCase": 1 }],
        "no-trailing-spaces": "warn",
        "eol-last": ["warn", "always"]
    },
    "ignorePatterns": [
        "node_modules/",
        "coverage/",
        "dist/",
        "build/"
    ]
}
