# Storm Scout Production Configuration
# Copy to .env.production and update values

# Server Configuration
PORT=3000
NODE_ENV=production

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_password_here
DB_NAME=storm_scout
# Set DB_SSL=true when the app and database communicate over TCP (separate servers).
# Leave false for localhost or Unix socket deployments (e.g., cPanel shared hosting).
DB_SSL=false

# Ingestion Configuration
INGESTION_ENABLED=true
INGESTION_INTERVAL_MINUTES=15

# NOAA Weather API Configuration
NOAA_API_BASE_URL=https://api.weather.gov
NOAA_API_USER_AGENT=StormScout/1.0 (usps-operations@example.com)

# CORS Configuration (REQUIRED — no default, omitting blocks all cross-origin requests)
# Comma-separate multiple origins: https://a.example.com,https://b.example.com
CORS_ORIGIN=https://your-usps-domain.example.com

# Reverse Proxy
# Set to true ONLY when a reverse proxy (LiteSpeed, Nginx, Apache) sits in front
# of this app and rewrites X-Forwarded-For. Required for accurate rate limiting
# on cPanel/LiteSpeed shared hosting. Defaults to false (disabled).
TRUST_PROXY=true

# API Key Authentication (REQUIRED for write endpoints)
# Protects /api/operational-status POST endpoints.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# PRODUCTION NOTE: When deployed behind the USPS enterprise reverse proxy,
# supplement this with SAML 2.0 / SSO via the business IDM system at the
# proxy layer.  That will provide full authentication for all endpoints
# (read and write) without application-level changes.
API_KEY=generate-a-64-char-random-hex-value-here

# Logging
LOG_LEVEL=info
# Set LOG_FORMAT=json to emit structured JSON request logs (for Splunk, CloudWatch, etc.)
# LOG_FORMAT=json

# Rate Limiting
# Override the default 30,000 req/60-min per-IP API limit.
# Lower this if abuse is detected; raise it if corporate NAT users are still blocked.
# RATE_LIMIT_API_MAX=30000

# DB connection pool size. Raise if pool exhaustion (HTTP 503) is observed under peak load.
# Verify MariaDB max_connections before increasing (run: SHOW VARIABLES LIKE 'max_connections').
# DB_POOL_LIMIT=40

# Optional: Additional Data Sources
# STATE_EMERGENCY_API_KEY=your_key_here
# FEMA_API_KEY=your_key_here
