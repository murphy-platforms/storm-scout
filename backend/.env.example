# Storm Scout Backend Configuration

# Server Configuration
PORT=3000
NODE_ENV=development

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=storm_scout
DB_PASSWORD=your_password_here
DB_NAME=storm_scout

# Ingestion Configuration
INGESTION_ENABLED=true
INGESTION_INTERVAL_MINUTES=15

# NOAA Weather API Configuration
# Register for API access at: https://www.weather.gov/documentation/services-web-api
NOAA_API_BASE_URL=https://api.weather.gov
NOAA_API_USER_AGENT=StormScout/1.0 (your-email@example.com)
# Note: NOAA API doesn't require an API key but requires a User-Agent header

# Optional: Additional Data Sources
# Add API keys/credentials for other weather/emergency data sources here
# STATE_EMERGENCY_API_KEY=your_key_here
# FEMA_API_KEY=your_key_here

# CORS Configuration
CORS_ORIGIN=http://localhost:8080

# Logging
LOG_LEVEL=info
