{
  "name": "storm-scout-backend",
  "version": "2.3.0",
  "releasedDate": "2026-03-29",
  "description": "Storm Scout backend API - Weather advisory dashboard for office locations",
  "main": "src/server.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "init-db": "node src/config/init-database.js",
    "seed-db": "node src/config/seed-database.js",
    "migrate": "node src/scripts/run-migrations.js",
    "migrate:status": "node src/scripts/run-migrations.js --status",
    "migrate:baseline": "node src/scripts/run-migrations.js --baseline",
    "ingest": "node src/ingestion/run-ingestion.js",
    "cleanup": "node src/utils/cleanup-advisories.js",
    "generate-locations": "node src/scripts/generate-osm-locations.js",
    "map-stations": "node scripts/map-observation-stations.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write 'src/**/*.js' '../frontend/js/**/*.js'",
    "format:check": "prettier --check 'src/**/*.js' '../frontend/js/**/*.js'",
    "prepare": "cd .. && husky .husky"
  },
  "lint-staged": {
    "src/**/*.js": "prettier --write",
    "../frontend/js/**/*.js": "prettier --write"
  },
  "keywords": [
    "weather",
    "advisory",
    "dashboard",
    "operations"
  ],
  "author": "Storm Scout Contributors",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.15.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.3.1",
    "helmet": "^8.1.0",
    "mysql2": "^3.20.0",
    "node-cache": "^5.1.2",
    "node-cron": "^3.0.3",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-junit": "^16.0.0",
    "lint-staged": "^15.5.2",
    "nodemon": "^3.0.2",
    "prettier": "^3.2.0",
    "supertest": "^7.0.0"
  },
  "overrides": {
    "qs": "6.14.2",
    "flatted": "3.4.2"
  },
  "overrideReasons": {
    "qs": "Pinned to 6.14.2 to patch two transitive-dependency vulnerabilities: CVE-2026-2391 (prototype pollution via qs) and CVE-2026-27903 (minimatch ReDoS via qs transitive chain). Review on each major qs or axios release — remove override once upstream ships a clean version. See docs/security/README.md § Dependency Overrides.",
    "flatted": "Pinned to 3.4.2 to patch GHSA-rf6f-7fwh-wjgh (prototype pollution via flatted parse() in <=3.4.1), pulled transitively through eslint -> file-entry-cache -> flat-cache. Review on eslint/file-entry-cache upgrades and remove when upstream resolves without this override."
  }
}
